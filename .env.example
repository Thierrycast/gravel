DATABASE_URL="file:./dev.db"

# Pluggy (Open Finance) — obrigatórias.
# De onde vêm: crie uma Application em https://dashboard.pluggy.ai
# Guia completo (contas, MeuPluggy, autorização): docs/meu-pluggy-setup.md
PLUGGY_CLIENT_ID=""
PLUGGY_CLIENT_SECRET=""
# Opcionais (os defaults abaixo já são os corretos)
PLUGGY_API_BASE="https://api.pluggy.ai"
PLUGGY_API_KEY_HEADER="X-API-KEY"
PLUGGY_AUTH_PATH="/auth"
PLUGGY_CONNECT_TOKEN_PATH="/connect_token"
PLUGGY_API_KEY_TTL_SECONDS="7200"

# Binance (cripto) — opcional; crie uma API key read-only em https://www.binance.com
BINANCE_API_KEY=""
BINANCE_API_SECRET=""
BINANCE_API_BASE="https://api.binance.com"
BINANCE_RECV_WINDOW="5000"

# Protege os endpoints internos em /api/admin/*
INTERNAL_API_KEY=""

# Web Push (notificações do PWA) — gere com `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
