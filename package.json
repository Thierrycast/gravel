{
  "name": "gravel",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack && pnpm prepare:standalone",
    "prepare:standalone": "rm -rf .next/standalone/.next/static .next/standalone/public && cp -R .next/static .next/standalone/.next/static && cp -R public .next/standalone/public",
    "start": "node .next/standalone/server.js",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "gravel": "tsx --env-file=.env cli/index.ts",
    "mcp": "tsx --env-file=.env mcp/server.ts"
  },
  "dependencies": {
    "@locator/runtime": "^0.5.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.0",
    "@serwist/next": "^9.5.11",
    "@tanstack/query-sync-storage-persister": "^5.100.9",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-persist-client": "^5.100.9",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "cli-table3": "^0.6.5",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "d3-sankey": "^0.12.3",
    "d3-shape": "^3.2.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "next-view-transitions": "^0.3.5",
    "ora": "^9.3.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-pluggy-connect": "^2.12.0",
    "recharts": "2.15.4",
    "serwist": "^9.5.11",
    "shadcn": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@tailwindcss/postcss": "^4",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
