// Prisma schema for the financial dashboard (SQLite for now)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum RecurringType {
  INCOME
  EXPENSE
}

enum RecurringInterval {
  WEEKLY
  MONTHLY
  YEARLY
}

enum BillStatus {
  OPEN
  CLOSED
  PAID
}

enum AccountType {
  BANK
  CASH
  CARD
  INVESTMENT
  CRYPTO
}

enum SourceProvider {
  PLUGGY
  BINANCE
  MANUAL
}

enum DomainAccountKind {
  BANK
  CASH
  CARD
  INVESTMENT
  CRYPTO
  OTHER
}

enum DomainTransactionDirection {
  INFLOW
  OUTFLOW
  TRANSFER
}

enum DomainCategoryKind {
  INCOME
  EXPENSE
  TRANSFER
  OTHER
}

enum RuleMatchType {
  EXACT
  CONTAINS
  PREFIX
  REGEX
}

enum OpsRunStatus {
  RUNNING
  SUCCESS
  ERROR
}

model Account {
  id        String        @id @default(cuid())
  name      String
  type      AccountType
  currency  String        @default("BRL")
  balance   Decimal       @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  transactions Transaction[]
  bills        Bill[]
  recurring    RecurringItem[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  type      CategoryType
  color     String?   // hex or token
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  transactions Transaction[]
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Decimal
  description String?
  date        DateTime
  createdAt   DateTime        @default(now())

  account   Account   @relation(fields: [accountId], references: [id])
  accountId String

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?
}

model RecurringItem {
  id          String            @id @default(cuid())
  title       String
  type        RecurringType
  amount      Decimal
  interval    RecurringInterval
  nextDate    DateTime
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())

  account   Account? @relation(fields: [accountId], references: [id])
  accountId String?
}

model Bill {
  id          String     @id @default(cuid())
  periodStart DateTime
  periodEnd   DateTime
  dueDate     DateTime
  total       Decimal
  status      BillStatus @default(OPEN)
  createdAt   DateTime   @default(now())

  account   Account @relation(fields: [accountId], references: [id])
  accountId String
}

model CryptoAsset {
  id        String   @id @default(cuid())
  symbol    String
  name      String
  amount    Decimal
  avgPrice  Decimal
  lastPrice Decimal
  updatedAt DateTime @updatedAt
}

model PortfolioSnapshot {
  id        String   @id @default(cuid())
  date      DateTime
  netWorth  Decimal
  createdAt DateTime @default(now())
}

model BalanceProjection {
  id               String   @id @default(cuid())
  date             DateTime
  projectedBalance Decimal
  createdAt        DateTime @default(now())
}

model PluggyItem {
  id            String   @id @default(cuid())
  pluggyItemId  String   @unique
  connectorId   Int?
  connectorName String?
  status        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PluggySyncRun {
  id           String   @id @default(cuid())
  scope        String   @default("full")
  resources    String
  status       String
  summaryJson  String?
  errorMessage String?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
}

model PluggyPayloadSnapshot {
  id               String   @id @default(cuid())
  resourceType     String
  externalId       String
  itemExternalId   String?
  parentExternalId String?
  payloadHash      String
  payloadJson      String
  sourceUpdatedAt  DateTime?
  fetchedAt        DateTime @default(now())

  @@unique([resourceType, externalId, payloadHash])
  @@index([resourceType, externalId, fetchedAt])
  @@index([itemExternalId])
}

model PluggyAccountRecord {
  id                String    @id @default(cuid())
  externalId        String    @unique
  itemExternalId    String
  type              String?
  subtype           String?
  name              String?
  number            String?
  owner             String?
  taxNumber         String?
  currencyCode      String?
  balance           Decimal?
  providerCreatedAt DateTime?
  providerUpdatedAt DateTime?
  createdAt         DateTime  @default(now())

  @@index([itemExternalId])
}

model PluggyAccountBalanceSnapshot {
  id                           String    @id @default(cuid())
  accountExternalId            String
  balance                      Decimal?
  blockedBalance               Decimal?
  automaticallyInvestedBalance Decimal?
  currencyCode                 String?
  providerUpdatedAt            DateTime?
  payloadHash                  String
  payloadJson                  String
  fetchedAt                    DateTime  @default(now())

  @@unique([accountExternalId, payloadHash])
  @@index([accountExternalId, fetchedAt])
}

model PluggyTransactionRecord {
  id                String    @id @default(cuid())
  externalId        String    @unique
  itemExternalId    String
  accountExternalId String
  description       String?
  descriptionRaw    String?
  currencyCode      String?
  amount            Decimal?
  date              DateTime?
  type              String?
  status            String?
  categoryId        String?
  category          String?
  providerCode      String?
  providerId        String?
  merchantCnpj      String?
  merchantName      String?
  providerCreatedAt DateTime?
  providerUpdatedAt DateTime?
  createdAt         DateTime  @default(now())

  @@index([itemExternalId])
  @@index([accountExternalId, date])
  @@index([merchantCnpj])
}

model PluggyInvestmentRecord {
  id                String    @id @default(cuid())
  externalId        String    @unique
  itemExternalId    String
  name              String?
  type              String?
  subtype           String?
  status            String?
  currencyCode      String?
  balance           Decimal?
  amountOriginal    Decimal?
  amountProfit      Decimal?
  providerCreatedAt DateTime?
  providerUpdatedAt DateTime?
  createdAt         DateTime  @default(now())

  @@index([itemExternalId])
}

model PluggyLoanRecord {
  id                    String    @id @default(cuid())
  externalId            String    @unique
  itemExternalId        String
  contractNumber        String?
  productName           String?
  contractAmount        Decimal?
  currencyCode          String?
  dueDate               DateTime?
  installmentPeriodicity String?
  status                String?
  providerCreatedAt     DateTime?
  providerUpdatedAt     DateTime?
  createdAt             DateTime  @default(now())

  @@index([itemExternalId])
}

model PluggyBillRecord {
  id                      String    @id @default(cuid())
  externalId              String    @unique
  itemExternalId          String?
  accountExternalId       String?
  dueDate                 DateTime?
  totalAmount             Decimal?
  totalAmountCurrencyCode String?
  minimumPaymentAmount    Decimal?
  allowsInstallments      Boolean?
  providerCreatedAt       DateTime?
  providerUpdatedAt       DateTime?
  createdAt               DateTime  @default(now())

  @@index([itemExternalId])
  @@index([accountExternalId])
}

model PluggyCategoryRecord {
  id                    String   @id @default(cuid())
  externalId            String   @unique
  description           String?
  descriptionTranslated String?
  parentId              String?
  parentDescription     String?
  createdAt             DateTime @default(now())
}

model PluggyMerchantRecord {
  id           String   @id @default(cuid())
  cnpj         String   @unique
  externalId   String?
  name         String?
  businessName String?
  category     String?
  cnae         String?
  createdAt    DateTime @default(now())
}

model BinanceSyncRun {
  id           String   @id @default(cuid())
  scope        String   @default("full")
  resources    String
  status       String
  summaryJson  String?
  errorMessage String?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
}

model BinanceAccountSnapshot {
  id           String   @id @default(cuid())
  payloadHash  String   @unique
  payloadJson  String
  updateTime   DateTime?
  fetchedAt    DateTime @default(now())
}

model BinanceAssetRecord {
  id        String   @id @default(cuid())
  asset     String   @unique
  createdAt DateTime @default(now())
}

model BinanceAssetBalanceSnapshot {
  id          String   @id @default(cuid())
  asset       String
  free        Decimal
  locked      Decimal
  total       Decimal
  payloadHash String
  payloadJson String
  fetchedAt   DateTime @default(now())

  @@unique([asset, payloadHash])
  @@index([asset, fetchedAt])
}

model BinanceAssetPriceSnapshot {
  id          String   @id @default(cuid())
  asset       String
  symbol      String
  quoteAsset  String
  price       Decimal
  payloadHash String
  payloadJson String
  fetchedAt   DateTime @default(now())

  @@unique([asset, symbol, payloadHash])
  @@index([asset, fetchedAt])
}

model BinanceTradeRecord {
  id              String   @id @default(cuid())
  symbol          String
  tradeId         String
  orderId         String?
  baseAsset       String?
  quoteAsset      String?
  price           Decimal
  quantity        Decimal
  quoteQuantity   Decimal?
  commission      Decimal?
  commissionAsset String?
  isBuyer         Boolean?
  isMaker         Boolean?
  isBestMatch     Boolean?
  tradedAt        DateTime?
  payloadJson     String
  createdAt       DateTime @default(now())

  @@unique([symbol, tradeId])
  @@index([baseAsset, tradedAt])
  @@index([quoteAsset, tradedAt])
  @@index([symbol, tradedAt])
}

model OpsSyncRun {
  id           String       @id @default(cuid())
  provider     SourceProvider
  scope        String
  resource     String
  status       OpsRunStatus
  trigger      String       @default("manual")
  requestJson  String?
  summaryJson  String?
  errorMessage String?
  startedAt    DateTime     @default(now())
  finishedAt   DateTime?

  failures OpsSyncFailure[]

  @@index([provider, resource, startedAt])
  @@index([status, startedAt])
}

model OpsSyncFailure {
  id         String         @id @default(cuid())
  runId      String?
  provider   SourceProvider
  resource   String
  scopeId    String?
  message    String
  metaJson   String?
  createdAt  DateTime       @default(now())

  run OpsSyncRun? @relation(fields: [runId], references: [id])

  @@index([provider, resource, createdAt])
  @@index([scopeId])
}

model OpsSyncCheckpoint {
  id         String         @id @default(cuid())
  provider   SourceProvider
  resource   String
  cursorKey  String
  value      String?
  metaJson   String?
  updatedAt  DateTime       @updatedAt
  createdAt  DateTime       @default(now())

  @@unique([provider, resource, cursorKey])
  @@index([provider, resource, updatedAt])
}

model OpsSyncLock {
  id        String   @id @default(cuid())
  lockKey   String   @unique
  owner     String
  lockedAt  DateTime @default(now())
  expiresAt DateTime
}

model DomainSyncState {
  id                  String       @id @default(cuid())
  stateKey            String       @unique
  status              OpsRunStatus @default(SUCCESS)
  lastProjectedAt     DateTime?
  lastSourceUpdatedAt DateTime?
  metaJson            String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model DomainCategory {
  id               String             @id @default(cuid())
  slug             String             @unique
  name             String
  kind             DomainCategoryKind @default(OTHER)
  color            String?
  sourceProvider   SourceProvider?
  sourceExternalId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([sourceProvider, sourceExternalId])
}

model DomainMerchant {
  id             String   @id @default(cuid())
  displayName    String
  normalizedName String   @unique
  cnpj           String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DomainMerchantSource {
  id               String         @id @default(cuid())
  domainMerchantId String
  sourceProvider   SourceProvider
  sourceExternalId String
  sourceName       String?
  sourceCnpj       String?
  createdAt        DateTime       @default(now())

  @@unique([sourceProvider, sourceExternalId])
  @@index([domainMerchantId])
}

model MerchantAliasRule {
  id          String         @id @default(cuid())
  provider    SourceProvider?
  matchType   RuleMatchType
  matchValue  String
  merchantId  String?
  aliasName   String?
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([provider, active])
}

model DomainAccount {
  id               String            @id @default(cuid())
  name             String
  normalizedName   String?
  kind             DomainAccountKind
  currencyCode     String            @default("BRL")
  balance          Decimal?
  sourceProvider   SourceProvider
  sourceExternalId String
  sourceParentId   String?
  ownerName        String?
  institutionName  String?
  metadataJson     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([sourceProvider, sourceExternalId])
  @@index([kind, updatedAt])
}

model DomainAccountSource {
  id               String         @id @default(cuid())
  domainAccountId  String
  sourceProvider   SourceProvider
  sourceExternalId String
  sourceParentId   String?
  createdAt        DateTime       @default(now())

  @@unique([sourceProvider, sourceExternalId])
  @@index([domainAccountId])
}

model DomainTransaction {
  id                    String                     @id @default(cuid())
  occurredAt            DateTime
  description           String?
  normalizedDescription String?
  amount                Decimal
  currencyCode          String?
  direction             DomainTransactionDirection
  sourceProvider        SourceProvider
  sourceExternalId      String
  sourceParentId        String?
  domainAccountId       String?
  domainMerchantId      String?
  domainCategoryId      String?
  providerCategoryId    String?
  merchantName          String?
  merchantCnpj          String?
  ignored               Boolean                    @default(false)
  metadataJson          String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  @@unique([sourceProvider, sourceExternalId])
  @@index([occurredAt])
  @@index([domainAccountId, occurredAt])
  @@index([domainCategoryId, occurredAt])
  @@index([domainMerchantId, occurredAt])
}

model DomainTransactionSource {
  id                  String         @id @default(cuid())
  domainTransactionId String
  sourceProvider      SourceProvider
  sourceExternalId    String
  sourceParentId      String?
  createdAt           DateTime       @default(now())

  @@unique([sourceProvider, sourceExternalId])
  @@index([domainTransactionId])
}

model IgnoredTransaction {
  id                  String   @id @default(cuid())
  domainTransactionId String   @unique
  reason              String?
  createdAt           DateTime @default(now())
}

model DomainBill {
  id                    String         @id @default(cuid())
  sourceProvider        SourceProvider
  sourceExternalId      String
  sourceParentId        String?
  domainAccountId       String?
  dueDate               DateTime?
  totalAmount           Decimal?
  minimumPaymentAmount  Decimal?
  currencyCode          String?
  allowsInstallments    Boolean?
  status                String?
  metadataJson          String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@unique([sourceProvider, sourceExternalId])
  @@index([dueDate])
}

model DomainInvestment {
  id               String         @id @default(cuid())
  name             String
  type             String?
  subtype          String?
  balance          Decimal?
  currencyCode     String?
  status           String?
  sourceProvider   SourceProvider
  sourceExternalId String
  sourceParentId   String?
  ownerName        String?
  metadataJson     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([sourceProvider, sourceExternalId])
  @@index([status, updatedAt])
}

model DomainCryptoAsset {
  id               String         @id @default(cuid())
  asset            String         @unique
  quantity         Decimal
  price            Decimal?
  value            Decimal?
  quoteAsset       String?
  sourceProvider   SourceProvider @default(BINANCE)
  sourceExternalId String?
  costBasis        Decimal?
  pnlUnrealized    Decimal?
  metadataJson     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model DomainRecurringRule {
  id                 String   @id @default(cuid())
  name               String
  merchantId         String?
  categoryId         String?
  descriptionPattern String?
  amount             Decimal?
  interval           String?
  active             Boolean  @default(true)
  metadataJson       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ── Goals ────────────────────────────────────────────────────────────────────

model Goal {
  id                  String   @id @default(cuid())
  name                String
  emoji               String   @default("🎯")
  targetAmount        Decimal
  currentAmount       Decimal  @default(0)
  monthlyContribution Decimal  @default(0)
  targetDate          DateTime?
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ── Tags ─────────────────────────────────────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionTag {
  id                  String   @id @default(cuid())
  domainTransactionId String
  tagId               String
  createdAt           DateTime @default(now())

  @@unique([domainTransactionId, tagId])
  @@index([tagId])
  @@index([domainTransactionId])
}

// ── Rules ────────────────────────────────────────────────────────────────────

model CategoryRule {
  id               String         @id @default(cuid())
  provider         SourceProvider?
  matchType        RuleMatchType
  matchField       String
  matchValue       String
  domainCategoryId String?
  active           Boolean        @default(true)
  priority         Int            @default(100)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([provider, active, priority])
}
