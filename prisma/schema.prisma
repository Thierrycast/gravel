// Prisma schema for the financial dashboard (SQLite).
//
// The canonical source of truth for user-facing financial data is the set of
// `Domain*` models populated by projectors in `lib/domain/projectors.ts` from
// provider-specific raw ingestion tables (`Pluggy*`, `Binance*`). Historical
// parallel legacy models (`Account`, `Transaction`, `Category`, `Bill`,
// `RecurringItem`, `CryptoAsset`) have been removed — use `DomainAccount`,
// `DomainTransaction`, `DomainCategory`, `DomainBill`, `DomainRecurringRule`,
// and `DomainCryptoAsset` instead.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum SourceProvider {
  PLUGGY
  BINANCE
  MANUAL
}

enum DomainAccountKind {
  BANK
  CASH
  CARD
  INVESTMENT
  CRYPTO
  OTHER
}

enum DomainTransactionDirection {
  INFLOW
  OUTFLOW
  TRANSFER
}

enum DomainCategoryKind {
  INCOME
  EXPENSE
  TRANSFER
  OTHER
}

enum RuleMatchType {
  EXACT
  CONTAINS
  PREFIX
  REGEX
}

enum OpsRunStatus {
  RUNNING
  SUCCESS
  ERROR
}

// ── Domain read models ───────────────────────────────────────────────────────

model DomainAccount {
  id               String            @id @default(cuid())
  name             String
  normalizedName   String?
  kind             DomainAccountKind
  currencyCode     String            @default("BRL")
  balance          Decimal?
  sourceProvider   SourceProvider
  sourceExternalId String
  sourceParentId   String?
  ownerName        String?
  institutionName  String?
  metadataJson     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  transactions     DomainTransaction[]
  bills            DomainBill[]


  @@unique([sourceProvider, sourceExternalId])
  @@index([kind, updatedAt])
}

model DomainAccountSource {
  id               String         @id @default(cuid())
  domainAccountId  String
  sourceProvider   SourceProvider
  sourceExternalId String
  sourceParentId   String?
  createdAt        DateTime       @default(now())

  @@unique([sourceProvider, sourceExternalId])
  @@index([domainAccountId])
}

model DomainTransaction {
  id                    String                     @id @default(cuid())
  occurredAt            DateTime
  description           String?
  normalizedDescription String?
  amount                Decimal
  currencyCode          String?
  direction             DomainTransactionDirection
  sourceProvider        SourceProvider
  sourceExternalId      String
  sourceParentId        String?
  domainAccountId       String?
  domainMerchantId      String?
  domainCategoryId      String?
  providerCategoryId    String?
  merchantName          String?
  merchantCnpj          String?
  ignored               Boolean                    @default(false)
  metadataJson          String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  domainAccount         DomainAccount?             @relation(fields: [domainAccountId], references: [id])
  domainCategory        DomainCategory?            @relation(fields: [domainCategoryId], references: [id])
  domainMerchant         DomainMerchant?            @relation(fields: [domainMerchantId], references: [id])


  @@unique([sourceProvider, sourceExternalId])
  @@index([domainMerchantId, occurredAt])
  @@index([domainCategoryId, occurredAt])
  @@index([domainAccountId, occurredAt])
  @@index([occurredAt, amount])
  @@index([direction, occurredAt, amount])
  @@index([occurredAt])
}

model DomainTransactionSource {
  id                  String         @id @default(cuid())
  domainTransactionId String
  sourceProvider      SourceProvider
  sourceExternalId    String
  sourceParentId      String?
  createdAt           DateTime       @default(now())

  @@unique([sourceProvider, sourceExternalId])
  @@index([domainTransactionId])
}

model DomainCategory {
  id               String             @id @default(cuid())
  slug             String             @unique
  name             String
  kind             DomainCategoryKind @default(OTHER)
  color            String?
  sourceProvider   SourceProvider?
  sourceExternalId String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  transactions     DomainTransaction[]


  @@unique([sourceProvider, sourceExternalId])
}

model DomainMerchant {
  id             String   @id @default(cuid())
  displayName    String
  normalizedName String   @unique
  cnpj           String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  transactions   DomainTransaction[]

}

model DomainMerchantSource {
  id               String         @id @default(cuid())
  domainMerchantId String
  sourceProvider   SourceProvider
  sourceExternalId String
  sourceName       String?
  sourceCnpj       String?
  createdAt        DateTime       @default(now())

  @@unique([sourceProvider, sourceExternalId])
  @@index([domainMerchantId])
}

model DomainBill {
  id                   String         @id @default(cuid())
  sourceProvider       SourceProvider
  sourceExternalId     String
  sourceParentId       String?
  domainAccountId      String?
  dueDate              DateTime?
  totalAmount          Decimal?
  minimumPaymentAmount Decimal?
  currencyCode         String?
  allowsInstallments   Boolean?
  status               String?
  metadataJson         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  domainAccount        DomainAccount? @relation(fields: [domainAccountId], references: [id])


  @@unique([sourceProvider, sourceExternalId])
  @@index([dueDate])
}

model DomainInvestment {
  id               String         @id @default(cuid())
  name             String
  type             String?
  subtype          String?
  balance          Decimal?
  currencyCode     String?
  status           String?
  sourceProvider   SourceProvider
  sourceExternalId String
  sourceParentId   String?
  ownerName        String?
  metadataJson     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([sourceProvider, sourceExternalId])
  @@index([status, updatedAt])
}

model DomainCryptoAsset {
  id               String         @id @default(cuid())
  asset            String         @unique
  quantity         Decimal
  price            Decimal?
  value            Decimal?
  quoteAsset       String?
  sourceProvider   SourceProvider @default(BINANCE)
  sourceExternalId String?
  costBasis        Decimal?
  pnlUnrealized    Decimal?
  metadataJson     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model DomainRecurringRule {
  id                 String   @id @default(cuid())
  name               String
  merchantId         String?
  categoryId         String?
  descriptionPattern String?
  amount             Decimal?
  interval           String?
  active             Boolean  @default(true)
  metadataJson       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model DomainSyncState {
  id                  String       @id @default(cuid())
  stateKey            String       @unique
  status              OpsRunStatus @default(SUCCESS)
  lastProjectedAt     DateTime?
  lastSourceUpdatedAt DateTime?
  metaJson            String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model IgnoredTransaction {
  id                  String   @id @default(cuid())
  domainTransactionId String   @unique
  reason              String?
  createdAt           DateTime @default(now())
}

// ── Rules ────────────────────────────────────────────────────────────────────

model CategoryRule {
  id               String          @id @default(cuid())
  provider         SourceProvider?
  matchType        RuleMatchType
  matchField       String
  matchValue       String
  domainCategoryId String?
  active           Boolean         @default(true)
  priority         Int             @default(100)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([provider, active, priority])
}

model MerchantAliasRule {
  id         String          @id @default(cuid())
  provider   SourceProvider?
  matchType  RuleMatchType
  matchValue String
  merchantId String?
  aliasName  String?
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([provider, active])
}

// ── Cached projections (rebuilt by lib/domain/derived.ts) ────────────────────

model PortfolioSnapshot {
  id        String   @id @default(cuid())
  date      DateTime
  netWorth  Decimal
  createdAt DateTime @default(now())
}

model DomainCryptoPosition {
  id            String   @id @default(cuid())
  asset         String   @unique
  quantity      Decimal
  costBasis     Decimal
  averagePrice  Decimal
  pnlUnrealized Decimal?
  lastUpdatedAt DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model DomainBalanceAnchor {
  id                String   @id @default(cuid())
  domainAccountId   String
  year              Int
  month             Int
  balance           Decimal
  transactionsCount Int      @default(0)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@unique([domainAccountId, year, month])
  @@index([domainAccountId, year, month])
}

model MacroSeriesPoint {
  id        String   @id @default(cuid())
  series    String   // e.g. "CDI", "IPCA"
  date      DateTime
  value     Decimal
  createdAt DateTime @default(now())

  @@unique([series, date])
  @@index([series, date])
}



model BalanceProjection {
  id               String   @id @default(cuid())
  date             DateTime
  projectedBalance Decimal
  createdAt        DateTime @default(now())
}

// ── Goals ────────────────────────────────────────────────────────────────────

model Goal {
  id                  String    @id @default(cuid())
  name                String
  emoji               String    @default("🎯")
  targetAmount        Decimal
  currentAmount       Decimal   @default(0)
  monthlyContribution Decimal   @default(0)
  targetDate          DateTime?
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ── Tags ─────────────────────────────────────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionTag {
  id                  String   @id @default(cuid())
  domainTransactionId String
  tagId               String
  createdAt           DateTime @default(now())

  @@unique([domainTransactionId, tagId])
  @@index([domainTransactionId])
  @@index([tagId])
}

// ── Pluggy ingestion (raw records + snapshots) ───────────────────────────────

model PluggyItem {
  id            String   @id @default(cuid())
  pluggyItemId  String   @unique
  connectorId   Int?
  connectorName String?
  status        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PluggySyncRun {
  id           String    @id @default(cuid())
  scope        String    @default("full")
  resources    String
  status       String
  summaryJson  String?
  errorMessage String?
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
}

model PluggyPayloadSnapshot {
  id               String    @id @default(cuid())
  resourceType     String
  externalId       String
  itemExternalId   String?
  parentExternalId String?
  payloadHash      String
  payloadJson      String
  sourceUpdatedAt  DateTime?
  fetchedAt        DateTime  @default(now())

  @@unique([resourceType, externalId, payloadHash])
  @@index([itemExternalId])
  @@index([resourceType, externalId, fetchedAt])
}

model PluggyAccountRecord {
  id                String    @id @default(cuid())
  externalId        String    @unique
  itemExternalId    String
  type              String?
  subtype           String?
  name              String?
  number            String?
  owner             String?
  taxNumber         String?
  currencyCode      String?
  balance           Decimal?
  providerCreatedAt DateTime?
  providerUpdatedAt DateTime?
  createdAt         DateTime  @default(now())

  @@index([itemExternalId])
}

model PluggyAccountBalanceSnapshot {
  id                           String    @id @default(cuid())
  accountExternalId            String
  balance                      Decimal?
  blockedBalance               Decimal?
  automaticallyInvestedBalance Decimal?
  currencyCode                 String?
  providerUpdatedAt            DateTime?
  payloadHash                  String
  payloadJson                  String
  fetchedAt                    DateTime  @default(now())

  @@unique([accountExternalId, payloadHash])
  @@index([accountExternalId, fetchedAt])
}

model PluggyTransactionRecord {
  id                String    @id @default(cuid())
  externalId        String    @unique
  itemExternalId    String
  accountExternalId String
  description       String?
  descriptionRaw    String?
  currencyCode      String?
  amount            Decimal?
  date              DateTime?
  type              String?
  status            String?
  categoryId        String?
  category          String?
  providerCode      String?
  providerId        String?
  merchantCnpj      String?
  merchantName      String?
  providerCreatedAt DateTime?
  providerUpdatedAt DateTime?
  createdAt         DateTime  @default(now())

  @@index([merchantCnpj])
  @@index([accountExternalId, date])
  @@index([itemExternalId])
}

model PluggyInvestmentRecord {
  id                String    @id @default(cuid())
  externalId        String    @unique
  itemExternalId    String
  name              String?
  type              String?
  subtype           String?
  status            String?
  currencyCode      String?
  balance           Decimal?
  amountOriginal    Decimal?
  amountProfit      Decimal?
  providerCreatedAt DateTime?
  providerUpdatedAt DateTime?
  createdAt         DateTime  @default(now())

  @@index([itemExternalId])
}

model PluggyLoanRecord {
  id                     String    @id @default(cuid())
  externalId             String    @unique
  itemExternalId         String
  contractNumber         String?
  productName            String?
  contractAmount         Decimal?
  currencyCode           String?
  dueDate                DateTime?
  installmentPeriodicity String?
  status                 String?
  providerCreatedAt      DateTime?
  providerUpdatedAt      DateTime?
  createdAt              DateTime  @default(now())

  @@index([itemExternalId])
}

model PluggyBillRecord {
  id                      String    @id @default(cuid())
  externalId              String    @unique
  itemExternalId          String?
  accountExternalId       String?
  dueDate                 DateTime?
  totalAmount             Decimal?
  totalAmountCurrencyCode String?
  minimumPaymentAmount    Decimal?
  allowsInstallments      Boolean?
  providerCreatedAt       DateTime?
  providerUpdatedAt       DateTime?
  createdAt               DateTime  @default(now())

  @@index([accountExternalId])
  @@index([itemExternalId])
}

model PluggyCategoryRecord {
  id                    String   @id @default(cuid())
  externalId            String   @unique
  description           String?
  descriptionTranslated String?
  parentId              String?
  parentDescription     String?
  createdAt             DateTime @default(now())
}

model PluggyMerchantRecord {
  id           String   @id @default(cuid())
  cnpj         String   @unique
  externalId   String?
  name         String?
  businessName String?
  category     String?
  cnae         String?
  createdAt    DateTime @default(now())
}

// ── Binance ingestion (raw records + snapshots) ──────────────────────────────

model BinanceSyncRun {
  id           String    @id @default(cuid())
  scope        String    @default("full")
  resources    String
  status       String
  summaryJson  String?
  errorMessage String?
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
}

model BinanceAccountSnapshot {
  id          String    @id @default(cuid())
  payloadHash String    @unique
  payloadJson String
  updateTime  DateTime?
  fetchedAt   DateTime  @default(now())
}

model BinanceAssetRecord {
  id        String   @id @default(cuid())
  asset     String   @unique
  createdAt DateTime @default(now())
}

model BinanceAssetBalanceSnapshot {
  id          String   @id @default(cuid())
  asset       String
  free        Decimal
  locked      Decimal
  total       Decimal
  payloadHash String
  payloadJson String
  fetchedAt   DateTime @default(now())

  @@unique([asset, payloadHash])
  @@index([asset, fetchedAt])
}

model BinanceAssetPriceSnapshot {
  id          String   @id @default(cuid())
  asset       String
  symbol      String
  quoteAsset  String
  price       Decimal
  payloadHash String
  payloadJson String
  fetchedAt   DateTime @default(now())

  @@unique([asset, symbol, payloadHash])
  @@index([asset, fetchedAt])
}

model BinanceTradeRecord {
  id              String    @id @default(cuid())
  symbol          String
  tradeId         String
  orderId         String?
  baseAsset       String?
  quoteAsset      String?
  price           Decimal
  quantity        Decimal
  quoteQuantity   Decimal?
  commission      Decimal?
  commissionAsset String?
  isBuyer         Boolean?
  isMaker         Boolean?
  isBestMatch     Boolean?
  tradedAt        DateTime?
  payloadJson     String
  createdAt       DateTime  @default(now())

  @@unique([symbol, tradeId])
  @@index([symbol, tradedAt])
  @@index([quoteAsset, tradedAt])
  @@index([baseAsset, tradedAt])
}

// ── Ops (sync runs, failures, checkpoints, locks) ────────────────────────────

model OpsSyncRun {
  id           String           @id @default(cuid())
  provider     SourceProvider
  scope        String
  resource     String
  status       OpsRunStatus
  trigger      String           @default("manual")
  requestJson  String?
  summaryJson  String?
  errorMessage String?
  startedAt    DateTime         @default(now())
  finishedAt   DateTime?
  failures     OpsSyncFailure[]

  @@index([status, startedAt])
  @@index([provider, resource, startedAt])
}

model OpsSyncFailure {
  id        String         @id @default(cuid())
  runId     String?
  provider  SourceProvider
  resource  String
  scopeId   String?
  message   String
  metaJson  String?
  createdAt DateTime       @default(now())
  run       OpsSyncRun?    @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([scopeId])
  @@index([provider, resource, createdAt])
}

model OpsSyncCheckpoint {
  id        String         @id @default(cuid())
  provider  SourceProvider
  resource  String
  cursorKey String
  value     String?
  metaJson  String?
  updatedAt DateTime       @updatedAt
  createdAt DateTime       @default(now())

  @@unique([provider, resource, cursorKey])
  @@index([provider, resource, updatedAt])
}

model OpsSyncLock {
  id        String   @id @default(cuid())
  lockKey   String   @unique
  owner     String
  lockedAt  DateTime @default(now())
  expiresAt DateTime
}
